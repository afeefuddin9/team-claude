# ── Anthropic ─────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Model to use (claude-sonnet-4-5 recommended for cost/quality balance)
# Options: claude-haiku-4-5  |  claude-sonnet-4-5  |  claude-opus-4-5
CLAUDE_MODEL=claude-sonnet-4-5

# ── Supabase ───────────────────────────────────────────────
# Get from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── App settings ──────────────────────────────────────────
# Your team or company name (shows in the sidebar)
NEXT_PUBLIC_TEAM_NAME=Lead with Tribe
